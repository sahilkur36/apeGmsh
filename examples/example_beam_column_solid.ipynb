{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Beam–Column Connection with 3-D Solid Elements\n",
    "\n",
    "This notebook demonstrates:\n",
    "\n",
    "1. Building an IPE200 cross-section as a **solid Part** (extruded I-shape)\n",
    "2. Assembling a vertical column + horizontal beam at a T-joint\n",
    "3. Fragmenting for a conformal mesh at the connection\n",
    "4. Adding **control nodes** at the beam tip and column base that are\n",
    "   NOT part of the conformal mesh — they are kinematically coupled\n",
    "   to the solid face nodes (similar to Abaqus `*COUPLING` / `*KINEMATIC`)\n",
    "5. Fixing the column base control node, applying a point load at the\n",
    "   beam tip control node\n",
    "6. Running a linear-elastic static analysis in OpenSees\n",
    "7. Visualising displacements in Gmsh\n",
    "\n",
    "**Units:** mm, N, s, tonne\n",
    "\n",
    "```\n",
    "       Z ↑\n",
    "         │     beam (along +X)\n",
    "         │    ┌─────────────────────── → tip (load P)\n",
    "column   │    │\n",
    "(along Z)│    │  ← connection at z = H_col/2\n",
    "         │    │\n",
    "         │\n",
    "        ═══  ← base (fixed)\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from __future__ import annotations\n",
    "\n",
    "import numpy as np\n",
    "import gmsh\n",
    "\n",
    "from pyGmsh import Part, Assembly, Numberer"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1 — Parameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# IPE200 cross-section (mm)\n",
    "h   = 200.0      # total depth\n",
    "b   = 100.0      # flange width\n",
    "tw  = 5.6        # web thickness\n",
    "tf  = 8.5        # flange thickness\n",
    "\n",
    "# Member lengths\n",
    "L_col  = 3000.0  # column height (Z)\n",
    "L_beam = 3000.0  # beam length   (X)\n",
    "\n",
    "# Connection: beam meets column at mid-height\n",
    "z_conn = L_col / 2.0\n",
    "\n",
    "# Material — structural steel (elastic)\n",
    "E   = 210_000.0   # MPa  (N/mm²)\n",
    "nu  = 0.3\n",
    "rho = 7.85e-9     # tonne/mm³\n",
    "\n",
    "# Load\n",
    "P = -10_000.0     # N, downward (−Z) at beam tip\n",
    "\n",
    "# Mesh\n",
    "LC = 25.0         # target element size (mm)\n",
    "\n",
    "print(f\"IPE200: h={h}, b={b}, tw={tw}, tf={tf} mm\")\n",
    "print(f\"Column: {L_col} mm | Beam: {L_beam} mm\")\n",
    "print(f\"Connection at z = {z_conn} mm\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2 — IPE200 solid Part builder\n",
    "\n",
    "Build the I cross-section from 12 vertices in the YZ plane,\n",
    "then extrude to a 3-D solid volume."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "def build_ipe200_part(name: str, length: float, extrude_axis: str = \"x\") -> Part:\n    \"\"\"\n    Build a solid IPE200 Part by extruding the I cross-section.\n\n    Cross-section is always perpendicular to the extrusion axis:\n      extrude along X → cross-section in YZ plane (x=0)\n                        flanges span Y, depth along Z\n      extrude along Z → cross-section in XY plane (z=0)\n                        depth along X (strong axis for X-loading),\n                        flanges span Y\n    \"\"\"\n    part = Part(name)\n    part.begin(verbose=False)\n\n    # I cross-section vertices (centred at origin)\n    # a = flange width direction, d = depth direction\n    pts = [\n        # Bottom flange\n        (-b/2, -h/2),           # 0\n        ( b/2, -h/2),           # 1\n        ( b/2, -h/2 + tf),      # 2\n        ( tw/2, -h/2 + tf),     # 3\n        # Web (right side)\n        ( tw/2,  h/2 - tf),     # 4\n        # Top flange\n        ( b/2,  h/2 - tf),      # 5\n        ( b/2,  h/2),           # 6\n        (-b/2,  h/2),           # 7\n        (-b/2,  h/2 - tf),      # 8\n        (-tw/2,  h/2 - tf),     # 9\n        # Web (left side)\n        (-tw/2, -h/2 + tf),     # 10\n        (-b/2, -h/2 + tf),      # 11\n    ]\n\n    # Place cross-section perpendicular to extrusion axis\n    gmsh_pts = []\n    for a, d in pts:\n        if extrude_axis == \"x\":\n            # YZ plane: flanges along Y, depth along Z\n            tag = part.model.add_point(0, a, d, sync=False)\n        elif extrude_axis == \"z\":\n            # XY plane: depth along X (strong axis), flanges along Y\n            tag = part.model.add_point(d, a, 0, sync=False)\n        else:\n            raise ValueError(f\"Unknown axis: {extrude_axis}\")\n        gmsh_pts.append(tag)\n\n    n = len(gmsh_pts)\n    lines = []\n    for i in range(n):\n        l = part.model.add_line(gmsh_pts[i], gmsh_pts[(i + 1) % n], sync=False)\n        lines.append(l)\n\n    loop = part.model.add_curve_loop(lines, sync=False)\n    surf = part.model.add_plane_surface(loop)  # syncs\n\n    if extrude_axis == \"x\":\n        dx, dy, dz = length, 0, 0\n    elif extrude_axis == \"z\":\n        dx, dy, dz = 0, 0, length\n\n    gmsh.model.occ.extrude([(2, surf)], dx, dy, dz)\n    gmsh.model.occ.synchronize()\n\n    part.properties[\"thickness_flange\"] = tf\n    part.properties[\"thickness_web\"]    = tw\n    part.properties[\"material\"]         = \"steel\"\n\n    return part"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3 — Build Parts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Column: I cross-section extruded along Z\n",
    "col_part = build_ipe200_part(\"column\", L_col, extrude_axis=\"z\")\n",
    "col_part.plot.geometry(label_tags=True, show=True)\n",
    "col_file = col_part.save(\"column.step\")\n",
    "col_part.end()\n",
    "print(f\"Column Part saved \\u2192 {col_file}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Beam: I cross-section extruded along X\n",
    "beam_part = build_ipe200_part(\"beam\", L_beam, extrude_axis=\"x\")\n",
    "beam_part.plot.geometry(label_tags=True, show=True)\n",
    "beam_file = beam_part.save(\"beam.step\")\n",
    "beam_part.end()\n",
    "print(f\"Beam Part saved   \\u2192 {beam_file}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4 — Create the Assembly\n",
    "\n",
    "| Instance | Part   | Translation       | Role                |\n",
    "|:---------|:-------|:------------------|:--------------------|\n",
    "| column   | column | (0, 0, 0)         | vertical member     |\n",
    "| beam     | beam   | (0, 0, z_conn)    | horizontal member   |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "asm = Assembly(\"BeamColumnConnection\")\n",
    "asm.begin(verbose=True)\n",
    "\n",
    "# Column: base at z=0, top at z=L_col\n",
    "i_col = asm.add_part(col_part, label=\"column\")\n",
    "print(f\"Column instance: {i_col.label}\")\n",
    "\n",
    "# Beam: translated so it connects at z = z_conn\n",
    "i_beam = asm.add_part(beam_part, label=\"beam\",\n",
    "                      translate=(0, 0, z_conn))\n",
    "print(f\"Beam instance:   {i_beam.label}\")\n",
    "\n",
    "print(f\"\\nInstances: {asm.list_instances()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5 — Fragment for conformal mesh\n",
    "\n",
    "The beam and column volumes overlap at the connection zone.\n",
    "`fragment_all()` splits all volumes at their intersections so the\n",
    "mesh will be conformal (shared nodes at the joint)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "surviving = asm.fragment_all(dim=3)\n",
    "print(f\"After fragmentation: {len(surviving)} volumes\")\n",
    "print(f\"Volume tags: {surviving}\")\n",
    "\n",
    "# Physical groups from instance labels\n",
    "groups = asm.add_physical_groups_from_instances(dim=3)\n",
    "print(f\"Physical groups: {groups}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot the assembled geometry\n",
    "asm.plot.geometry(label_tags=True, show=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6 — Mesh"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "gmsh.model.mesh.setSize(gmsh.model.getEntities(0), LC)\n",
    "gmsh.model.mesh.generate(3)\n",
    "\n",
    "node_tags_raw, coords_raw, _ = gmsh.model.mesh.getNodes()\n",
    "etypes, etags, _ = gmsh.model.mesh.getElements(3)\n",
    "n_nodes = len(node_tags_raw)\n",
    "n_elems = sum(len(et) for et in etags)\n",
    "print(f\"Mesh: {n_nodes} nodes, {n_elems} tet elements\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot the mesh\n",
    "asm.plot.mesh(show=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7 — Numbered mesh (solver-ready IDs)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mesh = asm.mesh.get_numbered_mesh(dim=3, method=\"rcm\")\n",
    "print(mesh.summary())\n",
    "print(f\"\\nNode ID range:    [{mesh.node_ids.min()}, {mesh.node_ids.max()}]\")\n",
    "print(f\"Element ID range: [{mesh.element_ids.min()}, {mesh.element_ids.max()}]\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 8 — Control nodes + Kinematic coupling\n\nWe add two **control nodes** that are NOT part of the conformal mesh:\n\n| Control node | Location           | Purpose        |\n|:-------------|:-------------------|:---------------|\n| Base         | Column base face   | Fixed BC       |\n| Tip          | Beam tip face      | Point load     |\n\n### The duplicate-node trick (solid-to-rigid coupling)\n\nSolid elements (tets) only have **3 translational DOFs**, but we want\nthe control nodes to carry all **6 DOFs** so we can apply full fixity\n(translations + rotations). The solution:\n\n1. Use `ndf=6` for the whole model\n2. **Fix DOFs 4-5-6** on all solid-only nodes (no rotational stiffness)\n3. Create **duplicate nodes** at each face position with 6 DOFs\n4. `rigidLink(\"beam\", ctrl_node, dup_node)` — full 6-DOF rigid coupling\n5. `equalDOF(dup_node, solid_node, 1, 2, 3)` — tie translations only\n\nThis is equivalent to Abaqus `*COUPLING, *KINEMATIC` on a solid surface."
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Find surface entities at column base and beam tip\n",
    "tol_face = 1.0  # mm\n",
    "\n",
    "col_base_surfs = []\n",
    "beam_tip_surfs = []\n",
    "\n",
    "for dim_s, tag_s in gmsh.model.getEntities(2):\n",
    "    bb = gmsh.model.getBoundingBox(dim_s, tag_s)\n",
    "    xmin, ymin, zmin, xmax, ymax, zmax = bb\n",
    "\n",
    "    # Column base: z_max ≈ 0\n",
    "    if abs(zmax) < tol_face and abs(zmin) < tol_face:\n",
    "        col_base_surfs.append(tag_s)\n",
    "\n",
    "    # Beam tip: x_min ≈ L_beam and x_max ≈ L_beam\n",
    "    if abs(xmin - L_beam) < tol_face and abs(xmax - L_beam) < tol_face:\n",
    "        if zmin >= z_conn - h/2 - tol_face and zmax <= z_conn + h/2 + tol_face:\n",
    "            beam_tip_surfs.append(tag_s)\n",
    "\n",
    "print(f\"Column base surfaces: {col_base_surfs}\")\n",
    "print(f\"Beam tip surfaces:    {beam_tip_surfs}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_face_nodes(surf_tags: list[int]) -> set[int]:\n",
    "    \"\"\"Get all mesh node tags on a list of surface entity tags.\"\"\"\n",
    "    nodes = set()\n",
    "    for stag in surf_tags:\n",
    "        ntags, _, _ = gmsh.model.mesh.getNodes(\n",
    "            dim=2, tag=stag, includeBoundary=True)\n",
    "        nodes.update(int(t) for t in ntags)\n",
    "    return nodes\n",
    "\n",
    "col_base_nodes_gmsh = get_face_nodes(col_base_surfs)\n",
    "beam_tip_nodes_gmsh = get_face_nodes(beam_tip_surfs)\n",
    "\n",
    "print(f\"Column base nodes: {len(col_base_nodes_gmsh)}\")\n",
    "print(f\"Beam tip nodes:    {len(beam_tip_nodes_gmsh)}\")\n",
    "\n",
    "# Map to solver IDs\n",
    "col_base_nodes = {mesh.gmsh_to_solver_node[t] for t in col_base_nodes_gmsh\n",
    "                  if t in mesh.gmsh_to_solver_node}\n",
    "beam_tip_nodes = {mesh.gmsh_to_solver_node[t] for t in beam_tip_nodes_gmsh\n",
    "                  if t in mesh.gmsh_to_solver_node}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Control node IDs — NEW nodes not in the mesh\n",
    "ctrl_base_id = int(mesh.node_ids.max() + 1)\n",
    "ctrl_tip_id  = int(mesh.node_ids.max() + 2)\n",
    "\n",
    "# Compute face centroids\n",
    "def face_centroid(node_set_solver: set[int]) -> np.ndarray:\n",
    "    \"\"\"Average coordinate of solver nodes in a set.\"\"\"\n",
    "    idxs = [np.searchsorted(mesh.node_ids, nid)\n",
    "            for nid in sorted(node_set_solver)]\n",
    "    return mesh.node_coords[idxs].mean(axis=0)\n",
    "\n",
    "base_centroid = face_centroid(col_base_nodes)\n",
    "tip_centroid  = face_centroid(beam_tip_nodes)\n",
    "\n",
    "print(f\"Control node {ctrl_base_id} (column base) at {base_centroid}\")\n",
    "print(f\"Control node {ctrl_tip_id}  (beam tip)    at {tip_centroid}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9 — Build OpenSees model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "import openseespy.opensees as ops\n\nops.wipe()\nops.model(\"basic\", \"-ndm\", 3, \"-ndf\", 6)\n\n# Material\nmat_tag = 1\nops.nDMaterial(\"ElasticIsotropic\", mat_tag, E, nu, rho)\n\n# Mesh nodes — fix rotational DOFs (4,5,6) on all solid nodes\n# since FourNodeTetrahedron provides no rotational stiffness\ncoupling_nodes = col_base_nodes | beam_tip_nodes\n\nfor i in range(mesh.n_nodes):\n    nid = int(mesh.node_ids[i])\n    x, y, z = mesh.node_coords[i]\n    ops.node(nid, float(x), float(y), float(z))\n    if nid not in coupling_nodes:\n        ops.fix(nid, 0, 0, 0, 1, 1, 1)  # fix rotations only\n\n# Coupling interface nodes: leave rz free for rigidLink\nfor nid in coupling_nodes:\n    ops.fix(int(nid), 0, 0, 0, 1, 1, 0)\n\nprint(f\"Created {mesh.n_nodes} mesh nodes\")\nprint(f\"  {mesh.n_nodes - len(coupling_nodes)} interior nodes (rot DOFs fixed)\")\nprint(f\"  {len(coupling_nodes)} coupling nodes (rz free)\")\n\n# Control nodes (full 6 DOFs)\nops.node(ctrl_base_id, *base_centroid.tolist())\nops.node(ctrl_tip_id,  *tip_centroid.tolist())\nprint(f\"Created 2 control nodes: {ctrl_base_id}, {ctrl_tip_id}\")"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Elements (4-node tets)\n",
    "for i in range(mesh.n_elems):\n",
    "    eid   = int(mesh.element_ids[i])\n",
    "    nodes = [int(n) for n in mesh.connectivity[i]]\n",
    "    ops.element(\"FourNodeTetrahedron\", eid, *nodes, mat_tag)\n",
    "\n",
    "print(f\"Created {mesh.n_elems} FourNodeTetrahedron elements\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "# Duplicate-node trick: solid-to-rigid coupling\n#\n# For each face node:\n#   1. Create a duplicate node at the same position (has 6 DOFs)\n#   2. rigidLink(\"beam\", ctrl_node, dup_node) — 6-DOF rigid body\n#   3. equalDOF(dup_node, solid_node, 1, 2, 3) — translations only\n\nnext_dup_id = ctrl_tip_id + 1\ndup_tags_base = []\ndup_tags_tip  = []\n\n# Column base\nfor solid_nid in sorted(col_base_nodes):\n    dup_id = next_dup_id\n    next_dup_id += 1\n    coords = ops.nodeCoord(int(solid_nid))\n    ops.node(dup_id, *coords)\n    ops.rigidLink(\"beam\", ctrl_base_id, dup_id)\n    ops.equalDOF(dup_id, int(solid_nid), 1, 2, 3)\n    dup_tags_base.append(dup_id)\n\n# Beam tip\nfor solid_nid in sorted(beam_tip_nodes):\n    dup_id = next_dup_id\n    next_dup_id += 1\n    coords = ops.nodeCoord(int(solid_nid))\n    ops.node(dup_id, *coords)\n    ops.rigidLink(\"beam\", ctrl_tip_id, dup_id)\n    ops.equalDOF(dup_id, int(solid_nid), 1, 2, 3)\n    dup_tags_tip.append(dup_id)\n\nprint(f\"Column base: {len(dup_tags_base)} dup nodes + rigidLinks\")\nprint(f\"  dup IDs: {dup_tags_base[0]}..{dup_tags_base[-1]}\")\nprint(f\"Beam tip:    {len(dup_tags_tip)} dup nodes + rigidLinks\")\nprint(f\"  dup IDs: {dup_tags_tip[0]}..{dup_tags_tip[-1]}\")"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "# Boundary conditions: FULL fixity at column base control node (all 6 DOFs)\nops.fix(ctrl_base_id, 1, 1, 1, 1, 1, 1)\nprint(f\"Fixed control node {ctrl_base_id} (column base) — all 6 DOFs\")\n\n# Loading: point load at beam tip control node (force in −Z)\nops.timeSeries(\"Linear\", 1)\nops.pattern(\"Plain\", 1, 1)\nops.load(ctrl_tip_id, 0.0, 0.0, float(P), 0.0, 0.0, 0.0)\nprint(f\"Applied load P = {P:.0f} N (−Z) at control node {ctrl_tip_id}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10 — Static analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "ops.constraints(\"Penalty\", 1e14, 1e14)\nops.numberer(\"RCM\")\nops.system(\"UmfPack\")\nops.test(\"NormDispIncr\", 1e-6, 50)\nops.algorithm(\"Newton\")\nops.integrator(\"LoadControl\", 0.1)\nops.analysis(\"Static\")\n\nprint(\"Running analysis...\")\nresult = ops.analyze(10)\nif result == 0:\n    print(\"Analysis converged successfully!\")\nelse:\n    print(f\"Analysis FAILED with code {result}\")"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "# Results\ntip_disp  = ops.nodeDisp(ctrl_tip_id)\nbase_disp = ops.nodeDisp(ctrl_base_id)\n\nprint(f\"Tip control node {ctrl_tip_id}:\")\nprint(f\"  ux = {tip_disp[0]:.4f} mm\")\nprint(f\"  uy = {tip_disp[1]:.4f} mm\")\nprint(f\"  uz = {tip_disp[2]:.4f} mm\")\nprint(f\"  rx = {tip_disp[3]:.6f} rad\")\nprint(f\"  ry = {tip_disp[4]:.6f} rad\")\nprint(f\"  rz = {tip_disp[5]:.6f} rad\")\n\nprint(f\"\\nBase control node {ctrl_base_id} (should be all zero — fixed):\")\nprint(f\"  u = [{base_disp[0]:.2e}, {base_disp[1]:.2e}, {base_disp[2]:.2e}]\")\n\n# Analytical check: cantilever beam tip deflection (Euler-Bernoulli)\n# IPE200 Iy = 1943 cm4 = 1943e4 mm4\nIy_approx = 1943e4  # mm4\ndelta_EB = abs(P) * L_beam**3 / (3 * E * Iy_approx)\nprint(f\"\\nEuler-Bernoulli estimate (beam only): d = {delta_EB:.4f} mm\")\nprint(f\"3-D FEM tip deflection (uz):          d = {abs(tip_disp[2]):.4f} mm\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11 — Gmsh displacement views"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build displacement array for mesh nodes (Gmsh tags)\n",
    "gmsh_tags_ordered = np.array(\n",
    "    [mesh.solver_to_gmsh_node[int(sid)] for sid in mesh.node_ids],\n",
    "    dtype=int,\n",
    ")\n",
    "disp_array = np.zeros((mesh.n_nodes, 3))\n",
    "for i in range(mesh.n_nodes):\n",
    "    nid = int(mesh.node_ids[i])\n",
    "    d = ops.nodeDisp(nid)\n",
    "    disp_array[i] = d[:3]\n",
